{
  "name": "@novu/thalamus",
  "packageManager": "pnpm@8.15.8",
  "version": "0.1.0-alpha.12",
  "publishConfig": {
    "access": "public"
  },
  "description": "Provider-agnostic managed AI agent runtime for Novu",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "typesVersions": {
    "*": {
      "anthropic": [
        "./dist/anthropic/index.d.ts"
      ],
      "anthropic/parser": [
        "./dist/anthropic/parser.d.ts"
      ],
      "openai": [
        "./dist/openai/index.d.ts"
      ],
      "openai/parser": [
        "./dist/openai/parser.d.ts"
      ],
      "vault": [
        "./dist/vault/index.d.ts"
      ],
      "durable": [
        "./dist/durable/index.d.ts"
      ],
      "webhook": [
        "./dist/webhook/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./anthropic": {
      "types": "./dist/anthropic/index.d.ts",
      "import": "./dist/anthropic/index.js",
      "require": "./dist/anthropic/index.cjs"
    },
    "./anthropic/parser": {
      "types": "./dist/anthropic/parser.d.ts",
      "import": "./dist/anthropic/parser.js",
      "require": "./dist/anthropic/parser.cjs"
    },
    "./openai": {
      "types": "./dist/openai/index.d.ts",
      "import": "./dist/openai/index.js",
      "require": "./dist/openai/index.cjs"
    },
    "./openai/parser": {
      "types": "./dist/openai/parser.d.ts",
      "import": "./dist/openai/parser.js",
      "require": "./dist/openai/parser.cjs"
    },
    "./vault": {
      "types": "./dist/vault/index.d.ts",
      "import": "./dist/vault/index.js",
      "require": "./dist/vault/index.cjs"
    },
    "./durable": {
      "types": "./dist/durable/index.d.ts",
      "import": "./dist/durable/index.js",
      "require": "./dist/durable/index.cjs"
    },
    "./webhook": {
      "types": "./dist/webhook/index.d.ts",
      "import": "./dist/webhook/index.js",
      "require": "./dist/webhook/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@anthropic-ai/aws-sdk": ">=0.86.0",
    "@anthropic-ai/sdk": ">=0.86.0",
    "@aws-crypto/sha256-js": ">=5.0.0",
    "@smithy/signature-v4": ">=3.0.0",
    "openai": ">=4.87.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@anthropic-ai/aws-sdk": {
      "optional": true
    },
    "@aws-crypto/sha256-js": {
      "optional": true
    },
    "@smithy/signature-v4": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@anthropic-ai/aws-sdk": "^0.3.0",
    "@anthropic-ai/sdk": "^0.98.0",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@biomejs/biome": "latest",
    "@smithy/signature-v4": "^5.4.1",
    "@types/node": "^25.7.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "openai": "latest",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "latest"
  }
}
